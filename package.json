{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.25.0",
  "workspaces": [
    "portfolio-client",
    "portfolio-server",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "scripts": {
    "install:all": "pnpm -w install",
    "build": "pnpm -r build",
    "db:up": "node scripts/db-up.mjs",
    "packages:watch": "pnpm --filter \"@ervum/*\" --parallel watch",
    "server:start:dev": "pnpm db:up && pnpm --filter \"portfolio-server\" start:dev",
    "client:start": "pnpm --filter \"portfolio-client\" start",
    "dev:all": "pnpm db:up && concurrently \"pnpm packages:watch\" \"pnpm server:start:dev\" \"pnpm client:start\""
  }
}